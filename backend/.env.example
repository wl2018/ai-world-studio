# Server
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this
MAX_ACCOUNTS=1  # Max number of accounts allowed to create

# OpenAI Compatible API
BASE_URL=https://127.0.0.1:5000/v1
API_KEY=your-api-key-here
MODEL=
#AI_SYSTEM_PROMPT=
TEMPERATURE=0.85
TEMPERATURE_RAW=0.9
TEMPERATURE_DETERMINE=0.7
TEMPERATURE_SUMMARY=0.8
MAX_TOKENS=4096
MAX_TOKENS_RAW=1024
# This require backend supports assistant perfill:
#ASSISTANT_PERFILL_PREFIX="<think>\n\n</think>\n\n"

PHASE1_TEMPERATURE=0.85
PHASE1_MAX_TOKENS=4096
#PHASE1_ASSISTANT_PERFILL_PREFIX="<think>\n\n</think>\n\n"
PHASE1_GREETING=1  # Generate greeting when a round is created. Positive integer n: for first n rounds, -1: always, 0 or obmit: never
#PHASE1_GREETING_REMOVE_TOOL_CALLS=1  # 1: remove tool call records after the greeting message is generated, 0 or obmit: don't remove

#PHASE2_BASE_URL=
#PHASE2_API_KEY=
#PHASE2_MODEL=
PHASE2_TEMPERATURE=0.9
PHASE2_MAX_TOKENS=1024
# PHASE2_PROMPTING_METHOD: 0: just ask assistant to generate more
# 1: use assistant perfill, 2: use user perfill (not implemented as it's generally not supported by API)
# 3: simulated assistant perfill (use chat template + /v1/completions API), 4: simulated user perfill
# 5: raw (use customized format and don't respect model's original template format)
# Current supported methods: 0,1,3,4,5
PHASE2_PROMPTING_METHOD=1
#PHASE2_ASSISTANT_PERFILL_PREFIX="<think>\n\n</think>\n\n"
